-- ------------------------------------------------------------
-- 维度表：日期
-- ------------------------------------------------------------
DROP TABLE IF EXISTS dim_date;
CREATE TABLE dim_date
(
    date_id INT COMMENT '日期ID，格式 YYYYMMDD',
    year    INT COMMENT '年',
    quarter STRING COMMENT '季度',
    month   INT COMMENT '月',
    day     INT COMMENT '日'
)
    COMMENT '日期维度表'
    STORED AS ORC
    TBLPROPERTIES ('orc.compress' = 'SNAPPY');

